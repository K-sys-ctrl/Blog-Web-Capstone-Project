<%- include("partials/header") %>

<h1>Create New Post</h1>

<form action="/compose" method="POST">

  <input
    type="text"
    name="title"
    placeholder="Post Title"
    required
  >

  <textarea
    name="content"
    placeholder="Write your post here..."
    rows="10"
    required
  ></textarea>

  <button type="submit">
    Publish Post
  </button>

</form>

<%- include("partials/footer") %>
