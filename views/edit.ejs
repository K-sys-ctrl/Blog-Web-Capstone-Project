```ejs id="y3a9pf"
<%- include("partials/header") %>

<h1>Edit Post</h1>

<form action="/posts/edit/<%= post.id %>" method="POST">

  <input
    type="text"
    name="title"
    value="<%= post.title %>"
    required
  >

  <textarea
    name="content"
    rows="10"
    required
  ><%= post.content %></textarea>

  <button type="submit">Update Post</button>

</form>

<%- include("partials/footer") %>
```
