<%- include("partials/header") %>

<h1>Welcome to My Blog</h1>

<p>Share your thoughts with the world.</p>

<% posts.forEach(post => { %>

  <div class="post-card">

    <h2><%= post.title %></h2>

    <p>
      <%= post.content.substring(0, 100) %>...
    </p>

    <a href="/posts/<%= post.id %>">Read More</a>

  </div>

<% }) %>

<%- include("partials/footer") %>